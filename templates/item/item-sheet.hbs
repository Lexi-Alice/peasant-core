<section class="pc-item-sheet-body">
  <header class="pc-item-header">
    <div class="pc-item-image-frame {{#if editable}}editing{{/if}}" data-pc-item-image-frame>
      <img class="pc-item-image" src="{{imageSrc}}" alt="{{item.name}}" style="{{imageStyle}}">
      {{#if editable}}
        <div class="pc-item-image-controls">
          <button type="button" class="pc-item-image-control-btn" data-pc-item-image-picker data-tooltip="Change Image" aria-label="Change Image">
            <i class="fa-solid fa-image" aria-hidden="true"></i>
          </button>
        </div>
      {{/if}}
    </div>
    <div class="pc-item-identity">
      <div class="pc-item-title-row">
        <input type="text" name="name" value="{{item.name}}" class="pc-item-name pc-input" placeholder="Name" {{#unless editable}}disabled{{/unless}}>
        <label class="pc-item-quantity" data-tooltip="Quantity" aria-label="Quantity">
          <span aria-hidden="true">x</span>
          <input type="number" name="system.quantity" value="{{quantityInput}}" class="pc-item-quantity-input pc-input" min="0" step="1" inputmode="numeric" {{#unless editable}}disabled{{/unless}}>
        </label>
      </div>
      <div class="pc-item-meta-row">
        <div class="pc-item-quality-stack">
          <select name="system.quality" class="pc-item-quality pc-input" aria-label="Item Quality" {{#unless editable}}disabled{{/unless}}>
            {{#each qualityOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
          <select name="system.magicType" class="pc-item-quality pc-input" aria-label="Item Magic Type" {{#unless editable}}disabled{{/unless}}>
            {{#each magicTypeOptions}}
              <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="pc-item-sunder" aria-label="Sunder">
          <div class="pc-item-sunder-heading">Sunder</div>
          <div class="pc-item-sunder-box skill-uses-box">
            <input type="number" name="system.sunder.current" value="{{sunderCurrentInput}}" class="pc-item-sunder-current skill-uses-current pc-input-plain" min="0" step="1" inputmode="numeric" aria-label="Sunder Current" {{#unless canEdit}}disabled{{/unless}}>
            <span class="uses-separator">/</span>
            <input type="number" name="system.sunder.max" value="{{sunderMaxInput}}" class="pc-item-sunder-max skill-uses-current pc-input-plain" min="0" step="1" inputmode="numeric" aria-label="Sunder Maximum" {{#unless editable}}disabled{{/unless}}>
          </div>
        </div>
        <div class="pc-item-measure-fields">
          <label class="pc-item-measure-row" data-tooltip="Value" aria-label="Value">
            <input type="number" name="system.value" value="{{valueInput}}" class="pc-item-measure-input pc-input" min="0" step="any" inputmode="decimal" {{#unless editable}}disabled{{/unless}}>
            <select name="system.currency" class="pc-item-measure-unit pc-input" aria-label="Currency" {{#unless editable}}disabled{{/unless}}>
              {{#each currencyOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
          </label>
        </div>
      </div>
    </div>
  </header>

  <nav class="pc-item-tabs tabs sheet-tabs" role="tablist" aria-label="Item sheet sections">
    {{#each itemTabs}}
      <button type="button" class="pc-item-tab {{cssClass}}" data-tab="{{tab}}" data-pc-item-tab="{{tab}}" role="tab" aria-selected="{{#if active}}true{{else}}false{{/if}}" {{#unless active}}tabindex="-1"{{/unless}}>
        <i class="{{icon}}" aria-hidden="true"></i>
        <span>{{label}}</span>
      </button>
    {{/each}}
  </nav>

  <section class="pc-item-tab-content">
    <section class="pc-item-tab-panel {{#if activeTabs.description}}active{{/if}}" data-pc-item-tab-panel="description" role="tabpanel" aria-hidden="{{#if activeTabs.description}}false{{else}}true{{/if}}" {{#unless activeTabs.description}}hidden{{/unless}}>
      <fieldset class="pc-foundry-section pc-item-section pc-item-description-section">
        <legend>Description</legend>
        {{#if editable}}
          <prose-mirror name="system.description" class="pc-item-description-editor inventory-editor peasant-desc-editor" value="{{system.description}}" data-document-uuid="{{item.uuid}}"></prose-mirror>
        {{else}}
          <div class="pc-item-description">{{{descriptionHTML}}}</div>
        {{/if}}
      </fieldset>
    </section>

    <section class="pc-item-tab-panel {{#if activeTabs.details}}active{{/if}}" data-pc-item-tab-panel="details" role="tabpanel" aria-hidden="{{#if activeTabs.details}}false{{else}}true{{/if}}" {{#unless activeTabs.details}}hidden{{/unless}}>
      {{#if isEquipment}}
        <fieldset class="pc-foundry-section pc-item-section">
          <legend>Equipment Details</legend>
          <div class="pc-item-equipment-details">
            <label class="pc-item-equipment-type-row">
              <span>Equipment Type</span>
              <select name="system.category" class="pc-input pc-item-equipment-type-select" aria-label="Equipment Type" {{#unless editable}}disabled{{/unless}}>
                {{#each equipmentCategoryOptions}}
                  {{#if options}}
                    <optgroup label="{{label}}">
                      {{#each options}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                      {{/each}}
                    </optgroup>
                  {{else}}
                    <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/if}}
                {{/each}}
              </select>
            </label>
            {{#if isShieldEquipment}}
              <div class="pc-item-equipment-shield-row">
                <span>Shield</span>
                <div class="pc-item-equipment-shield-fields">
                  <label class="pc-item-equipment-shield-field">
                    <span>HP</span>
                    <input type="number" name="system.shield.hp" value="{{shieldHpInput}}" class="pc-input pc-item-equipment-shield-input" min="0" step="1" inputmode="numeric" aria-label="Shield HP" {{#unless editable}}disabled{{/unless}}>
                  </label>
                  <label class="pc-item-equipment-shield-field">
                    <span>Hardness</span>
                    <input type="number" name="system.shield.hardness" value="{{shieldHardnessInput}}" class="pc-input pc-item-equipment-shield-input" min="0" step="1" inputmode="numeric" aria-label="Shield Hardness" {{#unless editable}}disabled{{/unless}}>
                  </label>
                </div>
              </div>
            {{/if}}
          </div>
        </fieldset>
      {{/if}}
      {{#if isLoot}}
        <fieldset class="pc-foundry-section pc-item-section">
          <legend>Loot Details</legend>
          <div class="pc-item-loot-details">
            <label class="pc-item-loot-type-row">
              <span>Loot Type</span>
              <select name="system.category" class="pc-input pc-item-loot-type-select" aria-label="Loot Type" {{#unless editable}}disabled{{/unless}}>
                {{#each lootCategoryOptions}}
                  <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
          </div>
        </fieldset>
      {{/if}}
    </section>

    {{#if availableItemTabs.activities}}
      <section class="pc-item-tab-panel {{#if activeTabs.activities}}active{{/if}}" data-pc-item-tab-panel="activities" role="tabpanel" aria-hidden="{{#if activeTabs.activities}}false{{else}}true{{/if}}" {{#unless activeTabs.activities}}hidden{{/unless}}>
      </section>
    {{/if}}

    {{#if availableItemTabs.effects}}
      <section class="pc-item-tab-panel {{#if activeTabs.effects}}active{{/if}}" data-pc-item-tab-panel="effects" role="tabpanel" aria-hidden="{{#if activeTabs.effects}}false{{else}}true{{/if}}" {{#unless activeTabs.effects}}hidden{{/unless}}>
        <fieldset class="pc-foundry-section pc-item-section">
          <legend>Effects</legend>
          <section class="pc-inventory-browser pc-item-effects-browser" aria-label="Active Effects" data-pc-item-effects-browser data-pc-item-effects-grouped="{{#if effectsGroupedByType}}true{{else}}false{{/if}}">
            <div class="pc-inventory-toolbar pc-item-effects-toolbar">
              <div class="pc-inventory-search pc-item-effects-search" role="search" aria-label="Search Active Effects">
                <i class="fa-solid fa-search" aria-hidden="true"></i>
                <input type="search" class="pc-inventory-search-input pc-item-effects-search-input pc-input" placeholder="Search effects" autocomplete="off" aria-label="Search Active Effects" data-pc-item-effects-search>
                <button type="button" class="pc-inventory-toolbar-button pc-item-effects-sort-toggle active" data-tooltip="{{effectSortToggle.label}}" aria-label="{{effectSortToggle.label}}" aria-pressed="true" data-sort-mode="{{effectSortToggle.mode}}" data-pc-item-effects-sort-toggle>
                  <i class="{{effectSortToggle.icon}}" aria-hidden="true"></i>
                </button>
                <button type="button" class="pc-inventory-toolbar-button pc-item-effects-group-toggle{{#if effectGroupToggle.active}} active{{/if}}" data-tooltip="{{effectGroupToggle.label}}" aria-label="{{effectGroupToggle.label}}" aria-pressed="{{effectGroupToggle.pressed}}" data-pc-item-effects-group-toggle>
                  <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
                </button>
              </div>
            </div>

            <section class="pc-inventory-list pc-item-effects-list" data-pc-item-effects-list>
              <div class="pc-inventory-view pc-item-effects-view" data-pc-item-effects-view="grouped">
                {{#each effectSections as |section|}}
                  {{#if section.visible}}
                    <div class="pc-inventory-section pc-item-effects-section" data-pc-item-effects-section data-effect-type="{{section.type}}">
                      <header class="pc-inventory-section-header pc-item-effects-section-header">
                        <h3 class="pc-inventory-section-title pc-item-effects-section-title">
                          <i class="{{section.icon}}" aria-hidden="true"></i>
                          <span>{{section.label}}</span>
                        </h3>
                        <div class="pc-inventory-column pc-item-effects-column pc-item-effects-column-status">Status</div>
                        <div class="pc-inventory-column pc-item-effects-column pc-item-effects-column-controls"></div>
                      </header>

                      <ol class="pc-inventory-items pc-item-effects-items">
                        {{#each section.effects as |effect|}}
                          <li class="pc-inventory-item pc-item-effect" data-pc-item-effect data-effect-id="{{effect.id}}" data-effect-type="{{effect.type}}" data-search="{{effect.searchText}}" data-sort-manual="{{effect.sort}}" data-sort-alpha="{{effect.sortName}}">
                            <div class="pc-inventory-item-row pc-item-effect-row">
                              <button type="button" class="pc-inventory-item-summary pc-item-effect-summary" data-tooltip="{{effect.name}}" aria-label="Open {{effect.name}}" data-pc-item-open-effect>
                                <img class="pc-inventory-item-image pc-item-effect-icon" src="{{effect.icon}}" alt="">
                                <span class="pc-inventory-item-name-stack pc-item-effect-name-stack">
                                  <span class="pc-inventory-item-name pc-item-effect-name">{{effect.name}}</span>
                                  <span class="pc-inventory-item-subtitle pc-item-effect-subtitle">{{effect.subtitle}}</span>
                                </span>
                              </button>

                              <div class="pc-inventory-row-field pc-item-effect-state">{{effect.status}}</div>

                              <div class="pc-inventory-row-controls pc-item-effect-controls">
                                {{#if @root.canEdit}}
                                  <button type="button" class="pc-inventory-menu-toggle pc-item-effect-menu-toggle header-control icon fa-solid fa-ellipsis-vertical" data-tooltip="Effect Options" aria-label="Effect Options" data-pc-item-effect-menu></button>
                                {{/if}}
                              </div>
                            </div>
                          </li>
                        {{/each}}
                      </ol>
                    </div>
                  {{/if}}
                {{/each}}
              </div>

              <div class="pc-inventory-view pc-item-effects-view" data-pc-item-effects-view="flat" hidden>
                {{#if effectFlatSection.visible}}
                  <div class="pc-inventory-section pc-item-effects-section" data-pc-item-effects-section data-effect-type="{{effectFlatSection.type}}">
                    <header class="pc-inventory-section-header pc-item-effects-section-header">
                      <h3 class="pc-inventory-section-title pc-item-effects-section-title">
                        <i class="{{effectFlatSection.icon}}" aria-hidden="true"></i>
                        <span>{{effectFlatSection.label}}</span>
                      </h3>
                      <div class="pc-inventory-column pc-item-effects-column pc-item-effects-column-status">Status</div>
                      <div class="pc-inventory-column pc-item-effects-column pc-item-effects-column-controls"></div>
                    </header>

                    <ol class="pc-inventory-items pc-item-effects-items">
                      {{#each effectFlatSection.effects as |effect|}}
                        <li class="pc-inventory-item pc-item-effect" data-pc-item-effect data-effect-id="{{effect.id}}" data-effect-type="{{effect.type}}" data-search="{{effect.searchText}}" data-sort-manual="{{effect.sort}}" data-sort-alpha="{{effect.sortName}}">
                          <div class="pc-inventory-item-row pc-item-effect-row">
                            <button type="button" class="pc-inventory-item-summary pc-item-effect-summary" data-tooltip="{{effect.name}}" aria-label="Open {{effect.name}}" data-pc-item-open-effect>
                              <img class="pc-inventory-item-image pc-item-effect-icon" src="{{effect.icon}}" alt="">
                              <span class="pc-inventory-item-name-stack pc-item-effect-name-stack">
                                <span class="pc-inventory-item-name pc-item-effect-name">{{effect.name}}</span>
                                <span class="pc-inventory-item-subtitle pc-item-effect-subtitle">{{effect.subtitle}}</span>
                              </span>
                            </button>

                            <div class="pc-inventory-row-field pc-item-effect-state">{{effect.status}}</div>

                            <div class="pc-inventory-row-controls pc-item-effect-controls">
                              {{#if @root.canEdit}}
                                <button type="button" class="pc-inventory-menu-toggle pc-item-effect-menu-toggle header-control icon fa-solid fa-ellipsis-vertical" data-tooltip="Effect Options" aria-label="Effect Options" data-pc-item-effect-menu></button>
                              {{/if}}
                            </div>
                          </div>
                        </li>
                      {{/each}}
                    </ol>
                  </div>
                {{/if}}
              </div>

              {{#unless hasEffects}}
                <div class="pc-inventory-empty-state">No effects configured.</div>
              {{/unless}}
              <div class="pc-inventory-empty-state pc-item-effects-search-empty" hidden>No matching effects.</div>
            </section>

            {{#if editable}}
              <button type="button" class="add-effect-btn" data-pc-item-add-effect> + Add Effect </button>
            {{/if}}
          </section>
        </fieldset>
      </section>
    {{/if}}
  </section>
</section>
