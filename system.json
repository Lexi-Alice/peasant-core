{
  "id": "peasant-core",
  "title": "Peasant Core",
  "description": "A system for FoundryVTT, based on the Peasant Core RPG by AshenWolf. Ashenwolf is reachable at willsonw.author@gmail.com.",
  "version": "1.7",
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "url": "https://github.com/Lexi-Alice/peasant-core",
  "manifest": "https://github.com/Lexi-Alice/peasant-core/releases/latest/download/system.json",
  "download": "https://github.com/Lexi-Alice/peasant-core/releases/download/1.7/peasant-core.zip",
  "relationships": {
    "requires": [
      {
        "id": "socketlib",
        "type": "module",
        "manifest": "https://github.com/farling42/foundryvtt-socketlib/releases/latest/download/module.json",
        "compatibility": {
          "minimum": "1.0.0"
        }
      }
    ]
  },
  "authors": [
    {
      "name": "AshenWolf"
    }
  ],
  "socket": true,
  "esmodules": [
    "peasant-core.mjs"
  ],
  "packs": [
    {
      "name": "peasant-core-macro",
      "label": "Peasant Core Macros",
      "path": "packs/peasant-core-macro",
      "type": "Macro",
      "system": "peasant-core",
      "ownership": {
        "PLAYER": "LIMITED",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "peasant-core-table",
      "label": "Peasant Core Tables",
      "path": "packs/peasant-core-table",
      "type": "RollTable",
      "system": "peasant-core",
      "ownership": {
        "PLAYER": "LIMITED",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "styles": [
    "peasant-core.css"
  ],
  "media": [
    {
      "type": "setup",
      "url": "systems/peasant-core/ui/peasantcore-background.jpeg",
      "thumbnail": "systems/peasant-core/ui/peasantcore-background.jpeg"
    }
  ],
  "background": "systems/peasant-core/ui/peasantcore-background.jpeg",
  "primaryTokenAttribute": "health",
  "documentTypes": {
    "ActiveEffect": {
      "enchantment": {},
      "skill": {}
    },
    "Actor": {
      "character": {
        "htmlFields": [
          "biography",
          "inventory",
          "skills.*.description",
          "notableCombats.*.description",
          "flexibleAdvantageDescriptions.*"
        ]
      }
    },
    "Item": {
      "weapon": {
        "htmlFields": [
          "description"
        ]
      },
      "equipment": {
        "htmlFields": [
          "description"
        ]
      },
      "tool": {
        "htmlFields": [
          "description"
        ]
      },
      "consumable": {
        "htmlFields": [
          "description"
        ]
      },
      "loot": {
        "htmlFields": [
          "description"
        ]
      }
    }
  }
}
